#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")
echo "plugin_dir: $plugin_dir"

# shellcheck source=./lib/utils.bash
source "${plugin_dir}/lib/utils.bash"

mkdir -p "$ASDF_DOWNLOAD_PATH"

# Get the Go version from .tool-versions or use a default
GO_VERSION=$(asdf current golang 2>/dev/null | awk '{print $2}' || echo "latest")
echo "Using Go version: $GO_VERSION"

# Set up Go environment for this build
export GOROOT="$HOME/.asdf/installs/golang/$GO_VERSION/go"
export PATH="$HOME/.asdf/installs/golang/$GO_VERSION/go/bin:$PATH"
export GOPATH="$HOME/.asdf/installs/golang/$GO_VERSION/.go"
export GOBIN="$GOPATH/bin"

# Verify Go is available
go version || fail "Go not available. Please install golang via asdf first."

release_file="$ASDF_DOWNLOAD_PATH/$TOOL_NAME-$ASDF_INSTALL_VERSION.tar.gz"

# Download tar.gz file to the download directory
download_release "$ASDF_INSTALL_VERSION" "$release_file"

# Extract contents of tar.gz file into the download directory
tar -xzf "$release_file" -C "$ASDF_DOWNLOAD_PATH" || fail "Could not extract $release_file"

# Navigate to the extracted directory
extracted_dir=$(find "$ASDF_DOWNLOAD_PATH" -maxdepth 1 -type d -name "grpc-go-*" | head -1)
if [ -z "$extracted_dir" ]; then
    extracted_dir=$(find "$ASDF_DOWNLOAD_PATH" -maxdepth 1 -type d -name "grpc-go"* | head -1)
fi

if [ -z "$extracted_dir" ]; then
    fail "Could not find extracted grpc-go directory in $ASDF_DOWNLOAD_PATH"
fi

echo "Building from: $extracted_dir/cmd/$TOOL_NAME"

# Build protoc-gen-go-grpc binary with explicit Go environment
pushd "$extracted_dir/cmd/$TOOL_NAME" >/dev/null 2>&1 || fail "Could not find $TOOL_NAME in $extracted_dir/cmd"

# Build and output directly to asdf's bin directory
go build -o "$ASDF_INSTALL_PATH/bin/$TOOL_NAME" . || fail "Could not build $TOOL_NAME"

popd >/dev/null 2>&1 || exit 1

# Clean up
rm -rf "$extracted_dir"
rm -f "$release_file"

echo "Successfully built $TOOL_NAME $ASDF_INSTALL_VERSION"